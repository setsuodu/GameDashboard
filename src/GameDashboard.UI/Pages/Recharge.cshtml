@page
@model GameDashboard.UI.Pages.RechargeModel
@{
    ViewData["Title"] = "充值货币";
}

<h2>充值货币</h2>

<form method="post" class="row g-3">
    <div class="col-md-6">
        <label class="form-label">角色ID</label>
        <input asp-for="RoleId" class="form-control" placeholder="输入角色ID" required />
    </div>
    
    <div class="col-md-6">
        <label class="form-label">货币类型</label>
        <select asp-for="CurrencyType" class="form-select">
            <option value="Gold">金币</option>
            <option value="Diamond">钻石</option>
            <option value="BindGold">绑定金币</option>
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">充值数量</label>
        <input asp-for="Amount" type="number" class="form-control" required />
    </div>

    <div class="col-md-12">
        <label class="form-label">充值原因（可选）</label>
        <input asp-for="Reason" class="form-control" value="GM后台充值" />
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-success btn-lg">确认充值</button>
    </div>
</form>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success mt-3">@Model.SuccessMessage</div>
}