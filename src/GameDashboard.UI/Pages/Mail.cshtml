@page
@model GameDashboard.UI.Pages.MailModel
@{
    ViewData["Title"] = "发送GM邮件";
}

<h2>发送 GM 邮件</h2>

<form method="post">
    <div class="mb-3">
        <label>角色ID</label>
        <input asp-for="RoleId" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>邮件标题</label>
        <input asp-for="Title" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>邮件内容</label>
        <textarea asp-for="Content" class="form-control" rows="5" required></textarea>
    </div>

    <button type="submit" class="btn btn-primary">发送邮件</button>
</form>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success mt-3">@Model.SuccessMessage</div>
}