@page
@model GameDashboard.UI.Pages.Player.SearchModel
@{
    ViewData["Title"] = "查询角色";
}

<h2>查询角色</h2>

<form method="post" class="mb-4">
    <div class="input-group" style="max-width: 500px;">
        <input asp-for="RoleId" class="form-control form-control-lg" placeholder="请输入角色ID" />
        <button type="submit" class="btn btn-primary btn-lg">查询</button>
    </div>
</form>

@if (Model.Player != null)
{
    <div class="card">
        <div class="card-header bg-primary text-white">角色信息</div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr><th>角色ID</th><td>@Model.Player.RoleId</td></tr>
                <tr><th>角色名</th><td>@Model.Player.Name</td></tr>
                <tr><th>等级</th><td>@Model.Player.Level</td></tr>
                <tr><th>金币</th><td>@Model.Player.Gold</td></tr>
                <tr><th>钻石</th><td>@Model.Player.Diamond</td></tr>
                <tr><th>VIP等级</th><td>@Model.Player.VipLevel</td></tr>
            </table>
        </div>
    </div>
}